// Full name:    SpotObjectCounting_Chunked_Scalar_Internal_EndUser
// Abbreviation: SptCnt_Chnk_Scl_Int_EU

nextflow_process {
    name "Test SPTCNT_CHNK_SCL_INT_EU"
    script "../main.nf"
    process "SPTCNT_CHNK_SCL_INT_EU"

    test("Should run SptCnt chunked enduser") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['zarr'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
