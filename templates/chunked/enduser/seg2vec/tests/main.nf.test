// Full name:    SegmentationToVector_Chunked_Vector_Internal_EndUser
// Abbreviation: Seg2Vec_Chnk_Vec_Int_EU

nextflow_process {
    name "Test SEG2VEC_CHNK_VEC_INT_EU"
    script "../main.nf"
    process "SEG2VEC_CHNK_VEC_INT_EU"

    test("Should run Seg2Vec chunked enduser") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['zarr'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
