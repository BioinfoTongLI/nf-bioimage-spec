// Full name:    Rasterisation_Chunked_LabelMask_Internal_EndUser
// Abbreviation: Raster_Chnk_Msk_Int_EU

nextflow_process {
    name "Test RASTER_CHNK_MSK_INT_EU"
    script "../main.nf"
    process "RASTER_CHNK_MSK_INT_EU"

    test("Should run Raster chunked enduser") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['zarr'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
