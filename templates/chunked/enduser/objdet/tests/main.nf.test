// Full name:    SpotObjectDetection_Chunked_Tabular_Internal_EndUser
// Abbreviation: ObjDet_Chnk_Tab_Int_EU

nextflow_process {
    name "Test OBJDET_CHNK_TAB_INT_EU"
    script "../main.nf"
    process "OBJDET_CHNK_TAB_INT_EU"

    test("Should run ObjDet chunked enduser") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['zarr'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
