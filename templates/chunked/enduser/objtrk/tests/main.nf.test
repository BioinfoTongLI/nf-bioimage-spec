// Full name:    ObjectTracking_Chunked_TracksWithDivision_Internal_EndUser
// Abbreviation: ObjTrk_Chnk_TrkDiv_Int_EU

nextflow_process {
    name "Test OBJTRK_CHNK_TRKDIV_INT_EU"
    script "../main.nf"
    process "OBJTRK_CHNK_TRKDIV_INT_EU"

    test("Should run ObjTrk chunked enduser") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['zarr'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
