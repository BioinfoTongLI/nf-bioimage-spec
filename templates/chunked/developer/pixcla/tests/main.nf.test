// Full name:    PixelVoxelClassification_Chunked_LabelMask_Internal_Developer
// Abbreviation: PixCla_Chnk_Msk_Int_Dev

nextflow_process {
    name "Test PIXCLA_CHNK_MSK_INT_DEV"
    script "../main.nf"
    process "PIXCLA_CHNK_MSK_INT_DEV"

    test("Should run PixCla chunked developer") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['zarr'], checkIfExists: true),
                    file(params.test_data['model'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
