// Full name:    ImageProcessing_Chunked_Image_Internal_Developer
// Abbreviation: ImgProc_Chnk_Img_Int_Dev

nextflow_process {
    name "Test IMGPROC_CHNK_IMG_INT_DEV"
    script "../main.nf"
    process "IMGPROC_CHNK_IMG_INT_DEV"

    test("Should run ImgProc chunked developer") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['zarr'], checkIfExists: true),
                    file(params.test_data['model'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
