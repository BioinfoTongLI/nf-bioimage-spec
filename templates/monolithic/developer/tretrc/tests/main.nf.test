// Full name:    FilamentTreeTracing_Monolithic_SWC_Internal_Developer
// Abbreviation: TreTrc_Mono_SWC_Int_Dev

nextflow_process {
    name "Test TRETRC_MONO_SWC_INT_DEV"
    script "../main.nf"
    process "TRETRC_MONO_SWC_INT_DEV"

    test("Should run TreTrc monolithic developer") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['image'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
