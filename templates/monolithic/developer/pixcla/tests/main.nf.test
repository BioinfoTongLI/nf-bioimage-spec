// Full name:    PixelVoxelClassification_Monolithic_LabelMask_External_Developer
// Abbreviation: PixCla_Mono_Msk_Ext_Dev

nextflow_process {
    name "Test PIXCLA_MONO_MSK_EXT_DEV"
    script "../main.nf"
    process "PIXCLA_MONO_MSK_EXT_DEV"

    test("Should run PixCla monolithic developer") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['image'], checkIfExists: true),
                    file(params.test_data['model'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
