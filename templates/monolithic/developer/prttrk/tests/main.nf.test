// Full name:    ParticleTracking_Monolithic_Tracks_Internal_Developer
// Abbreviation: PrtTrk_Mono_Trk_Int_Dev

nextflow_process {
    name "Test PRTTRK_MONO_TRK_INT_DEV"
    script "../main.nf"
    process "PRTTRK_MONO_TRK_INT_DEV"

    test("Should run PrtTrk monolithic developer") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['image'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
