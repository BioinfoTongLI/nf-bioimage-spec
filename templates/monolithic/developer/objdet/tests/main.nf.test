// Full name:    SpotObjectDetection_Monolithic_Points_External_Developer
// Abbreviation: ObjDet_Mono_Pts_Ext_Dev

nextflow_process {
    name "Test OBJDET_MONO_PTS_EXT_DEV"
    script "../main.nf"
    process "OBJDET_MONO_PTS_EXT_DEV"

    test("Should run ObjDet monolithic developer") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['image'], checkIfExists: true),
                    file(params.test_data['model'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
