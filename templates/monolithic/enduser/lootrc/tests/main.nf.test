// Full name:    FilamentNetworkTracing_Monolithic_SkeletonMask_Internal_EndUser
// Abbreviation: LooTrc_Mono_Skl_Int_EU

nextflow_process {
    name "Test LOOTRC_MONO_SKL_INT_EU"
    script "../main.nf"
    process "LOOTRC_MONO_SKL_INT_EU"

    test("Should run LooTrc monolithic enduser") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['image'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
