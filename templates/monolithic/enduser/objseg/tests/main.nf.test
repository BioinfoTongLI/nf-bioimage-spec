// Full name:    ObjectSegmentation_Monolithic_Vector_External_EndUser
// Abbreviation: ObjSeg_Mono_Vec_Ext_EU

nextflow_process {
    name "Test OBJSEG_MONO_VEC_EXT_EU"
    script "../main.nf"
    process "OBJSEG_MONO_VEC_EXT_EU"

    test("Should run ObjSeg monolithic enduser") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['image'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
