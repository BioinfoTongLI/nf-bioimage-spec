// Full name:    LandmarkDetection_Monolithic_ClassMask_External_EndUser
// Abbreviation: LndDet_Mono_ClsMsk_Ext_EU

nextflow_process {
    name "Test LNDDET_MONO_CLSMSK_EXT_EU"
    script "../main.nf"
    process "LNDDET_MONO_CLSMSK_EXT_EU"

    test("Should run LndDet monolithic enduser") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['image'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
