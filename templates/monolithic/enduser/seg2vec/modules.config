// Abbreviation: Seg2Vec_Mono_Vec_Ext_EU

process {
    withName: 'SEG2VEC_MONO_VEC_EXT_EU' {
        ext.args = [
            // simplify tolerance
        ].join(' ')
        publishDir = [
            path: { "${params.outdir}/seg2vec" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
