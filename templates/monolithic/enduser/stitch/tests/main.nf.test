// Full name:    StitchingRegistration_Monolithic_Image_Internal_EndUser
// Abbreviation: Stitch_Mono_Img_Int_EU

nextflow_process {
    name "Test STITCH_MONO_IMG_INT_EU"
    script "../main.nf"
    process "STITCH_MONO_IMG_INT_EU"

    test("Should run Stitch monolithic enduser") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['image'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
