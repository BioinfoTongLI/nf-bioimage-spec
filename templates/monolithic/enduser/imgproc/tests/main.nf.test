// Full name:    ImageProcessing_Monolithic_Image_External_EndUser
// Abbreviation: ImgProc_Mono_Img_Ext_EU

nextflow_process {
    name "Test IMGPROC_MONO_IMG_EXT_EU"
    script "../main.nf"
    process "IMGPROC_MONO_IMG_EXT_EU"

    test("Should run ImgProc monolithic enduser") {
        when {
            process {
                """
                input[0] = [
                    [id: 'test', pixel_size_xy: 0.65],
                    file(params.test_data['image'], checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.findAll { key, val -> key.startsWith('versions') } }
            )
        }
    }
}
